# Discord
DISCORD_TOKEN=your_bot_token
CLIENT_ID=your_application_client_id
GUILD_ID=your_guild_id

# Database — Railway bot service (pick ONE approach):

# EASIEST: Reference from PostgreSQL → DATABASE_PRIVATE_URL (exact name on bot)
DATABASE_PRIVATE_URL=

# Or reference all 5 (must all be from the SAME Postgres service):
PGHOST=
PGPORT=
PGUSER=
PGPASSWORD=
PGDATABASE=

# Do NOT paste stale URLs. If you use this, it must be a Reference — not copy-paste:
DATABASE_URL=

# Roles & Channels
ADMIN_ROLE_ID=0
STAFF_ROLE_ID=0
TICKET_CATEGORY_ID=0
ELITE_INVITER_ROLE_ID=0
LEGEND_DRIVER_ROLE_ID=0

# Command registration (set true once to register slash commands)
REGISTER_COMMANDS=false

# Invite rewards & validation
INVITE_REWARD=100
MIN_INVITEE_ACCOUNT_AGE_DAYS=7
MIN_INVITEE_STAY_DAYS=7
MIN_INVITEE_MESSAGES=5
MIN_INVITEE_VC_TIME_MINS=30
INVITE_MILESTONE_5=200
INVITE_MILESTONE_10=500
INVITE_MILESTONE_25=1200
INVITE_MILESTONE_50=2500
INVITE_MILESTONE_100=6000

# Gambling
GAMBLE_MIN_BET=10
GAMBLE_MAX_BET=10000
COINFLIP_WIN_CHANCE=49
DICE_TARGET_MULTIPLIER=4.5
DICE_ADJACENT_MULTIPLIER=2
BLACKJACK_TIMEOUT_SECONDS=300

# Crates
CRATE_BRONZE_PRICE=250
CRATE_SILVER_PRICE=750
CRATE_GOLD_PRICE=2000

# Redeem (RC costs)
REDEEM_ONE_DOLLAR=1500
REDEEM_TWO_DOLLAR=3000
REDEEM_FIVE_DOLLAR=7000
REDEEM_TEN_DOLLAR=12000
REDEEM_FREE_RIDE=20000

# Cron schedules
SNAPSHOT_CRON_SCHEDULE=0 0 * * *
INVITE_VALIDATOR_CRON_SCHEDULE=0 * * * *

# Rate limits (milliseconds)
COMMAND_COOLDOWN_MS=3000
GAMBLE_COOLDOWN_MS=5000
CRATE_COOLDOWN_MS=5000

# Logging
LOG_LEVEL=info
