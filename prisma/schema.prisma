datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum BookingStatus {
  PENDING
  CLAIMED
  COMPLETED
  CANCELLED
}

enum ServiceType {
  RIDE
  COURIER
}

enum VehicleType {
  REGULAR
  COMFORT
  XL
}

model User {
  id        String   @id @default(cuid())
  discordId String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerBookings Booking[]     @relation("CustomerBookings")
  providerBookings Booking[]     @relation("ProviderBookings")
  providerStats    ProviderStats?
  vouchesGiven     Vouch[]       @relation("VouchCustomer")
  vouchesReceived  Vouch[]       @relation("VouchProvider")

  @@index([discordId])
}

model Booking {
  id            String        @id @default(cuid())
  bookingNumber String        @unique
  customerId    String
  providerId    String?
  preferredName String?
  serviceType   ServiceType
  vehicleType   VehicleType?
  pickup        String
  destination   String
  price         Decimal       @db.Decimal(10, 2)
  notes         String?
  status        BookingStatus @default(PENDING)
  rating        Int?
  channelId     String?
  messageId     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  claimedAt     DateTime?
  completedAt   DateTime?
  cancelledAt   DateTime?

  customer User?  @relation("CustomerBookings", fields: [customerId], references: [discordId])
  provider User?  @relation("ProviderBookings", fields: [providerId], references: [discordId])
  vouch    Vouch?

  @@index([customerId])
  @@index([providerId])
  @@index([status])
  @@index([customerId, status])
}

model BookingSequence {
  id         Int @id @default(1)
  lastNumber Int @default(0)
}

model ProviderStats {
  id        String   @id @default(cuid())
  discordId String   @unique
  claims    Int      @default(0)
  completed Int      @default(0)
  cancelled Int      @default(0)
  avgRating Decimal  @default(0) @db.Decimal(3, 2)
  revenue   Decimal  @default(0) @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [discordId], references: [discordId])

  @@index([discordId])
  @@index([completed])
  @@index([revenue])
}

model Vouch {
  id         String   @id @default(cuid())
  bookingId  String   @unique
  customerId String
  providerId String
  rating     Int
  createdAt  DateTime @default(now())

  booking  Booking @relation(fields: [bookingId], references: [id])
  customer User    @relation("VouchCustomer", fields: [customerId], references: [discordId])
  provider User    @relation("VouchProvider", fields: [providerId], references: [discordId])

  @@index([providerId])
}

model Blacklist {
  id        String   @id @default(cuid())
  discordId String   @unique
  reason    String?
  createdBy String
  createdAt DateTime @default(now())

  @@index([discordId])
}

model Panel {
  id        String   @id @default(cuid())
  key       String   @unique
  content   String
  channelId String?
  messageId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

// ───────────────────────────── Invite Reward System ─────────────────────────

enum InviteStatus {
  PENDING
  VERIFIED
  REWARDED
  FAKE
  REJECTED
}

enum InviteFakeReason {
  ALT_ACCOUNT
  LEFT_EARLY
  SELF_INVITE
  PREVIOUS_MEMBER
  BOT
  BAN_EVASION
  RATE_LIMIT
  MANUAL
  CAP
}

enum InviteRewardType {
  INVITE
  MILESTONE
  MANUAL
}

model InviteConfig {
  id                   String   @id @default(cuid())
  guildId              String   @unique
  rewardAmount         Int      @default(250)
  verificationDelaySec Int      @default(600)
  minAccountAgeDays    Int      @default(7)
  minMessages          Int      @default(0)
  maxVerifyAttempts    Int      @default(6)
  dailyCap             Int      @default(0)
  weeklyCap            Int      @default(0)
  monthlyCap           Int      @default(0)
  maxRewardsPerInviter Int      @default(0)
  antiAltEnabled       Boolean  @default(true)
  rewardEnabled        Boolean  @default(true)
  milestonesEnabled    Boolean  @default(true)
  lotteryEnabled       Boolean  @default(true)
  shopEnabled          Boolean  @default(true)
  weeklyResetEnabled   Boolean  @default(true)
  monthlyResetEnabled  Boolean  @default(true)
  ticketsPerDaily      Int      @default(1)
  ticketsPerInvite     Int      @default(5)
  ticketsPerRide       Int      @default(10)
  ticketsPerEvent      Int      @default(1)
  lotteryPrizeKey      String   @default("RIDE_FREE_20")
  loggingChannelId     String?
  announceChannelId    String?
  lotteryChannelId     String?
  autoAnnounce         Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([guildId])
}

model InviteCode {
  id        String   @id @default(cuid())
  guildId   String
  code      String
  inviterId String?
  uses      Int      @default(0)
  isVanity  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([guildId, code])
  @@index([guildId])
  @@index([inviterId])
}

model InviteJoin {
  id               String            @id @default(cuid())
  guildId          String
  invitedUserId    String
  inviterUserId    String?
  inviteCode       String?
  status           InviteStatus      @default(PENDING)
  fakeReason       InviteFakeReason?
  accountCreatedAt DateTime?
  joinedAt         DateTime          @default(now())
  verifyAt         DateTime
  verifiedAt       DateTime?
  leftAt           DateTime?
  rewarded         Boolean           @default(false)
  rewardAmount     Int?
  rewardTxnRef     String?
  verifyAttempts   Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([guildId, inviterUserId])
  @@index([guildId, invitedUserId])
  @@index([guildId, status])
  @@index([guildId, verifyAt])
}

model InviteUserStats {
  id                  String    @id @default(cuid())
  guildId             String
  userId              String
  verified            Int       @default(0)
  fake                Int       @default(0)
  pending             Int       @default(0)
  lifetime            Int       @default(0)
  rcEarned            Decimal   @default(0) @db.Decimal(18, 2)
  milestonesCompleted Int       @default(0)
  lastInviteAt        DateTime?
  streak              Int       @default(0)
  weeklyCount         Int       @default(0)
  monthlyCount        Int       @default(0)
  updatedAt           DateTime  @updatedAt

  @@unique([guildId, userId])
  @@index([guildId, verified])
}

model InviteReward {
  id            String           @id @default(cuid())
  guildId       String
  inviterUserId String
  invitedUserId String?
  joinId        String?
  amount        Decimal          @db.Decimal(18, 2)
  type          InviteRewardType @default(INVITE)
  reason        String
  createdAt     DateTime         @default(now())

  @@index([guildId, inviterUserId])
  @@index([guildId, type])
}

model InviteMilestone {
  id            String   @id @default(cuid())
  guildId       String
  threshold     Int
  rewardAmount  Int      @default(0)
  rewardRoleId  String?
  rewardRideKey String?
  rewardTickets Int      @default(0)
  label         String?
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([guildId, threshold])
  @@index([guildId])
}

model InviteMilestoneAward {
  id          String   @id @default(cuid())
  guildId     String
  userId      String
  milestoneId String
  awardedAt   DateTime @default(now())

  @@unique([guildId, userId, milestoneId])
  @@index([guildId, userId])
}

model InviteLog {
  id           String   @id @default(cuid())
  guildId      String
  event        String
  actorId      String?
  targetUserId String?
  inviteCode   String?
  joinId       String?
  detail       String?
  createdAt    DateTime @default(now())

  @@index([guildId, createdAt])
  @@index([guildId, event])
}

model InviteResetHistory {
  id          String   @id @default(cuid())
  guildId     String
  type        String
  performedBy String
  detail      String?
  createdAt   DateTime @default(now())

  @@index([guildId])
}

// ───────────────────────── Referral Economy Expansion ───────────────────────

enum RedemptionSource {
  SHOP
  MILESTONE
  LOTTERY
  MANUAL
}

enum RedemptionStatus {
  ACTIVE
  REDEEMED
  VOID
}

model Redemption {
  id         String           @id @default(cuid())
  guildId    String
  userId     String
  rewardKey  String
  code       String           @unique
  source     RedemptionSource @default(SHOP)
  status     RedemptionStatus @default(ACTIVE)
  costRc     Decimal?         @db.Decimal(18, 2)
  redeemedBy String?
  redeemedAt DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([guildId, userId])
  @@index([guildId, status])
}

model ShopItem {
  id        String   @id @default(cuid())
  guildId   String
  key       String
  label     String
  priceRc   Int
  rewardKey String
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([guildId, key])
  @@index([guildId])
}

model LotteryTicket {
  id        String   @id @default(cuid())
  guildId   String
  userId    String
  tickets   Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([guildId, userId])
  @@index([guildId])
}

model LotteryDraw {
  id             String   @id @default(cuid())
  guildId        String
  winnerUserId   String?
  totalTickets   Int      @default(0)
  participants   Int      @default(0)
  prizeKey       String
  redemptionCode String?
  drawnAt        DateTime @default(now())

  @@index([guildId, drawnAt])
}

model ScheduleState {
  id        String   @id @default(cuid())
  guildId   String
  key       String
  lastRunAt DateTime?
  updatedAt DateTime @updatedAt

  @@unique([guildId, key])
  @@index([guildId])
}

model InviteActivity {
  id            String    @id @default(cuid())
  guildId       String
  userId        String
  messageCount  Int       @default(0)
  lastMessageAt DateTime?
  updatedAt     DateTime  @updatedAt

  @@unique([guildId, userId])
  @@index([guildId])
}
